{
  "name": "@kidmemory/sidecar",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node src/main.ts",
    "test": "find tests -name '*.test.ts' -print0 | xargs -0 node --test",
    "test:unit": "find tests/unit -name '*.test.ts' -print0 | xargs -0 node --test",
    "test:integration": "node --test tests/contracts/*.test.ts tests/http/*.test.ts",
    "test:contracts": "node --test tests/contracts/*.test.ts",
    "lint": "eslint --max-warnings=0 \"src/**/*.ts\" \"tests/**/*.ts\"",
    "check:src": "node ../../scripts/check-sidecar-runtime-imports.mjs src",
    "check:tests": "find tests/unit -name '*.test.ts' -print0 | xargs -0 node --test",
    "build": "node --run lint && node --run check:src && node --run check:tests",
    "build:prod": "tsc -p tsconfig.build.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:dev": "prisma migrate dev"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@openai/agents": "^0.11.4",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/supabase-js": "^2.105.4",
    "adm-zip": "^0.5.16",
    "cors": "^2.8.6",
    "helmet": "^8.1.0",
    "openai": "^6.37.0",
    "pdfjs-dist": "^4.10.38",
    "playwright": "^1.49.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@types/node": "^22.19.19",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "eslint": "^9.34.0",
    "prisma": "^7.8.0",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=22"
  }
}
