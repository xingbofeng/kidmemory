            "description": "Number of items to skip",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "description": "Maximum items to return",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "deviceId",
            "required": false,
            "in": "query",
            "description": "Filter by device ID",
            "schema": {}
          }
        ],
        "responses": {
          "200": {
            "description": "Pending items retrieved"
          }
        },
        "summary": "Get pending sync upload items",
        "tags": [
          "upload-items"
        ]
      }
    },
    "/upload-items/{id}/sync-status": {
      "put": {
        "operationId": "UploadItemsController_updateSyncStatus",
