            "description": "Invalid status transition"
          },
          "404": {
            "description": "Item not found"
          }
        },
        "summary": "Update upload item sync status",
        "tags": [
          "upload-items"
        ]
      },
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ]
    },
