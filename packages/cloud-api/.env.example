# Cloud API Configuration

# Server
CLOUD_API_PORT=3002
CLOUD_API_HOST=0.0.0.0

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/kidmemory_cloud

# CORS
ALLOWED_ORIGINS=https://app.kidmemory.baby,http://localhost:5173

# Tencent COS object storage (for browser direct uploads)
COS_BUCKET=your-bucket-1250000000
COS_REGION=ap-guangzhou
COS_SECRET_ID=your-cos-secret-id
COS_SECRET_KEY=your-cos-secret-key
COS_SIGNED_URL_TTL_SECONDS=900

# Security
JWT_SECRET=your-jwt-secret-here
ENCRYPTION_KEY=your-32-char-encryption-key-here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
