POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=kidmemory
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=
OPENROUTER_BASE_URL=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

KIDMEMORY_WORKSPACE_DIR=.kidmemory/workspace
KIDMEMORY_EXPORT_DIR=.kidmemory/exports
KIDMEMORY_DATA_DIR=.kidmemory/data
KIDMEMORY_SIDECAR_HOST=127.0.0.1
KIDMEMORY_SIDECAR_PORT=4317

# Web Companion 前端部署的公开 URL（用于生成扫码链接和会话跳转）
WEB_COMPANION_BASE_URL=http://localhost:3001

# Supabase Storage 配置
SUPABASE_URL=https://your-project.supabase.co
# Supabase service role key 必须只保留在 sidecar 进程，永不下发给 Web Companion 前端
# 使用 service role key 生成 signed upload URL
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=kidmemory-assets
SUPABASE_STORAGE_PUBLIC_BASE_URL=https://your-project.supabase.co/storage/v1/object/public
# Signed upload URL 有效期（秒），默认 900 秒（15 分钟）
SUPABASE_STORAGE_SIGNED_URL_TTL_SECONDS=900
SUPABASE_S3_ENDPOINT=
SUPABASE_S3_REGION=auto
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_S3_BUCKET=

# Web Companion Supabase Direct Upload（已废弃，建议使用 Trusted Upload）
# Public anon key。Sidecar 通过 `POST /web-companion/direct-upload/sessions` 转发给 Web Companion 前端使用
# Supabase Storage policy 必须限制 anon 仅能写入 `web-companion-uploads/{sessionId}/...` 前缀
SUPABASE_ANON_KEY=
# Direct Upload 专用 bucket；建议与正式素材 bucket 隔离
SUPABASE_DIRECT_UPLOAD_BUCKET=web-companion-uploads
# Web Companion 静态部署的公开 URL，例如 https://kidmemory-companion.example.com
WEB_COMPANION_DIRECT_PUBLIC_URL=
# Feature flag。Direct Upload 默认关闭，开启后桌面端显示「扫码上传」入口
WEB_COMPANION_DIRECT_UPLOAD_ENABLED=false
# 体验约束：单次推荐张数（非安全约束）
WEB_COMPANION_DIRECT_RECOMMENDED_CLIENT_LIMIT=200
# 体验约束：建议会话有效期（秒），仅作为前端提示
WEB_COMPANION_DIRECT_EXPIRES_AT_HINT_SECONDS=10800

# Web Companion Trusted Upload（推荐）
# 使用后端可信会话、signed upload URL、自动 pullback 入库
# 无需额外配置，复用上述 SUPABASE_* 配置即可

# HTTP 安全配置
# 本地开发默认关闭 CSP，生产部署建议开启并配置允许访问的 Web Companion 域名
KIDMEMORY_HTTP_CSP_ENABLED=false
KIDMEMORY_HTTP_HELMET_ENABLED=true
KIDMEMORY_HTTP_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173
